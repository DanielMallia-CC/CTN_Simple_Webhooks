# --- CTN_NotionMeeting_CalEvent ---
# DynamoDB table storing Google OAuth tokens
DYNAMODB_TABLE_NAME=

# Secrets Manager secret for Google OAuth client credentials
SECRET_NAME=

# Secrets Manager ARN for the Notion API token
NOTION_TOKEN_SECRET=

# Notion database IDs
MEETINGS_DB_ID=
MUSICIAN_PORTAL_DB_ID=
SITE_VISITS_DB_ID=

# --- RSVP Sync ---
# Google Calendar ID to watch for RSVP changes (full email, e.g. user@gmail.com)
RSVP_CALENDAR_ID=
# Notion database ID for the RSVP datasource
NOTION_RSVP_DATASOURCE_ID=
# Secret slug in the webhook URL path (shared secret for push validation)
RSVP_WEBHOOK_SLUG=
# Token sent in X-Goog-Channel-Token header for push validation
RSVP_WEBHOOK_TOKEN=
# Full Lambda Function URL (used as the webhook address for events.watch)
RSVP_FUNCTION_URL=

# --- CTN_Feedback ---
# Notion database ID for the feedback source (triggers the webhook)
CTN_FEEDBACK_DB_ID=
# Notion database ID where action items are created
DAK_FEEDBACK_ACTIONS_DB_ID=
# Sprints database for linking actions to the current sprint
DAK_FEEDBACK_SPRINTS_DB_ID=
# Notion page ID for the project relation
DAK_FEEDBACK_PROJECT_PAGE_ID=
# Notion user ID for the default assignee
DAK_FEEDBACK_ASSIGNEE_PAGE_ID=
# Template IDs (optional)
DAK_FEEDBACK_BUG_TEMPLATE_ID=
DAK_FEEDBACK_ADMIN_TEMPLATE_ID=
